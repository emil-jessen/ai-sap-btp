{
  "name": "my-btp-app",
  "version": "1.0.0",
  "description": "SAP BTP application with CAP backend and SAP UI5 Fiori frontend",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/my-btp-app.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build --production",
    "test": "jest --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@sap/cds": "^7",
    "@sap/xssec": "^3",
    "passport": "^0",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7",
    "@sap/eslint-plugin-cds": "^2",
    "eslint": "^8",
    "jest": "^29",
    "mbt": "^1"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "xsuaa"
      },
      "destinations": {
        "kind": "destinations"
      }
    },
    "features": {
      "fetch_csrf": true
    }
  }
}
